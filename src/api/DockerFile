# Stage 1: install all deps (dev + prod) — cached until package.json/yarn.lock change
FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json yarn.lock ./

RUN yarn install --frozen-lockfile

# Stage 2: generate Prisma client and compile TypeScript
FROM node:22-alpine AS build

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# prisma.config.ts validates DATABASE_URL at generate time
ARG DATABASE_URL
RUN DATABASE_URL="$DATABASE_URL" npx prisma generate \
    && yarn build

# Stage 3: production-only node_modules (no dev tooling in final image)
FROM node:22-alpine AS prod-deps

WORKDIR /app

COPY package.json yarn.lock ./

RUN yarn install --production --frozen-lockfile --ignore-scripts

# Stage 4: minimal runtime image
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

RUN addgroup -S flowmesh && adduser -S flowmesh -G flowmesh

COPY --from=prod-deps /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY package.json ./

USER flowmesh

EXPOSE 5555

CMD ["node", "dist/src/index.js"]
