FROM node:22-alpine

WORKDIR /app

COPY package.json yarn.lock ./

RUN yarn install

COPY . .

# prisma.config.ts requires DATABASE_URL at build time for `prisma generate`
ARG DATABASE_URL
RUN DATABASE_URL="$DATABASE_URL" npx prisma generate

# Build the project
RUN yarn build

# Remove dev dependencies (optimize size)
RUN yarn install --production --ignore-scripts

EXPOSE 5555

CMD ["node", "dist/src/server.js"]